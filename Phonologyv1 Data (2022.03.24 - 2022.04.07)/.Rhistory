ggboxplot(dprimeMemory, x = 'type', y = 'aprime', color = 'predictType', add = 'jitter')
ggbarplot(dprimeMemory, x = 'type', y = 'dprime', fill = 'predictType', add = 'mean_se', position = position_dodge(0.8))# + geom_jitter(aes(x = type, y = dprime, fill = predictType), color = 'grey', alpha = 0.9, position = position_jitterdodge(jitter.width = 0.2, jitter.height = 0.1))
ggbarplot(dprimeMemory, x = 'type', y = 'aprime', fill = 'predictType', add = 'mean_se', position = position_dodge(0.8))# + geom_jitter(aes(x = type, y = aprime, fill = predictType), color = 'grey', alpha = 0.9, position = position_jitterdodge(jitter.width = 0.2, jitter.height = 0.1))
aprimeModel1 <- lmer(aprime ~ type + (1|subject), data = dprimeMemory)
anova(aprimeModel1)
summary(aprimeModel1)
aprimeModel2 <- lmer(aprime ~ type * predictType + (1|subject), data = dprimeMemory)
anova(aprimeModel2)
dprimeModel1 <- lmer(dprime ~ type + (1|subject), data = dprimeMemory)
anova(dprimeModel1)
dprimeModel2 <- lmer(dprime ~ type * predictType + (1|subject), data = dprimeMemory)
anova(dprimeModel2)
#Calculate false alarm rate
memoryFaRate <- memoryCount %>%
mutate(fa_rate = n_fa/(n_cr + n_fa))
ggplot(memoryFaRate, aes(x = type, y = fa_rate, color = predictType)) + geom_boxplot()
ggboxplot(memoryFaRate, x = 'type', y = 'fa_rate', color = 'predictType', add = 'jitter')
ggbarplot(memoryFaRate, x = 'type', y = 'fa_rate', fill = 'predictType', add = 'mean_se', position = position_dodge(0.8))# + geom_jitter(aes(x = type, y = fa_rate, fill = predictType), color = 'grey', alpha = 0.9, position = position_jitterdodge(jitter.width = 0.2, jitter.height = 0.1))
memoryFaRateModel1 <- lmer(fa_rate ~ type + (1|subject), data = memoryFaRate)
